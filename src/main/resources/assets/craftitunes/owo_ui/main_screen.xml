<owo-ui xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/wisp-forest/owo/1.21/owo-ui.xsd">
    <components>
        <flow-layout direction="vertical">
            <sizing>
                <horizontal method="fill">100</horizontal>
                <vertical method="fill">100</vertical>
            </sizing>
            <horizontal-alignment>center</horizontal-alignment>
            <vertical-alignment>center</vertical-alignment>

            <children>
                <!-- Main Window -->
                <flow-layout direction="horizontal">
                    <sizing>
                        <horizontal method="fixed">400</horizontal>
                        <vertical method="fixed">250</vertical>
                    </sizing>
                    <surface>
                        <panel dark="true"/>
                    </surface>
                    
                    <children>
                        <!-- Sidebar -->
                        <flow-layout direction="vertical">
                            <sizing>
                                <horizontal method="fixed">100</horizontal>
                                <vertical method="fill">100</vertical>
                            </sizing>
                            <padding>
                                <all>5</all>
                            </padding>
                            <surface>
                                <options-background/>
                            </surface>
                            
                            <children>
                                <label>
                                    <text>CraftiTunes</text>
                                    <shadow>true</shadow>
                                    <color>#1DB954</color>
                                    <margins><bottom>10</bottom></margins>
                                </label>
                                <button id="btn-local-files">
                                    <text>Local Files</text>
                                    <sizing><horizontal method="fill">100</horizontal></sizing>
                                </button>
                                <button id="btn-playlists">
                                    <text>Playlists</text>
                                    <sizing><horizontal method="fill">100</horizontal></sizing>
                                </button>
                                <button id="btn-queue">
                                    <text>Queue</text>
                                    <sizing><horizontal method="fill">100</horizontal></sizing>
                                </button>
                            </children>
                        </flow-layout>
                        
                        <!-- Main Content Area -->
                        <flow-layout direction="vertical">
                            <sizing>
                                <horizontal method="fill">100</horizontal>
                                <vertical method="fill">100</vertical>
                            </sizing>
                            <padding>
                                <all>10</all>
                            </padding>
                            
                            <children>
                                <!-- Top: Now Playing Info -->
                                <flow-layout direction="horizontal">
                                    <sizing>
                                        <horizontal method="fill">100</horizontal>
                                        <vertical method="fixed">30</vertical>
                                    </sizing>
                                    <vertical-alignment>center</vertical-alignment>
                                    <children>
                                        <label id="lbl-now-playing">
                                            <text>Now Playing: None</text>
                                            <shadow>true</shadow>
                                        </label>
                                    </children>
                                </flow-layout>
                                
                                <!-- Middle: Track List -->
                                <scroll direction="vertical">
                                    <flow-layout direction="vertical" id="track-list">
                                        <sizing>
                                            <horizontal method="fill">100</horizontal>
                                            <vertical method="content"></vertical>
                                        </sizing>
                                        <children>
                                            <label>
                                                <text>Loading tracks...</text>
                                            </label>
                                        </children>
                                    </flow-layout>
                                    
                                    <sizing>
                                        <horizontal method="fill">100</horizontal>
                                        <vertical method="fixed">150</vertical>
                                    </sizing>
                                    <margins>
                                        <top>5</top>
                                        <bottom>5</bottom>
                                    </margins>
                                </scroll>
                                
                                <!-- Bottom: Playback Controls -->
                                <flow-layout direction="vertical">
                                    <sizing>
                                        <horizontal method="fill">100</horizontal>
                                        <vertical method="fixed">45</vertical>
                                    </sizing>
                                    <horizontal-alignment>center</horizontal-alignment>
                                    <vertical-alignment>center</vertical-alignment>
                                    
                                    <children>
                                        <slider id="track-slider">
                                            <sizing>
                                                <horizontal method="fill">100</horizontal>
                                            </sizing>
                                            <margins><bottom>5</bottom></margins>
                                        </slider>
                                        
                                        <flow-layout direction="horizontal">
                                            <sizing>
                                                <horizontal method="content"></horizontal>
                                                <vertical method="content"></vertical>
                                            </sizing>
                                            <horizontal-alignment>center</horizontal-alignment>
                                            <vertical-alignment>center</vertical-alignment>
                                            <children>
                                                <button id="btn-prev">
                                                    <text>&lt;&lt;</text>
                                                    <sizing><horizontal method="fixed">30</horizontal></sizing>
                                                    <margins><right>5</right></margins>
                                                </button>
                                                <button id="btn-play-pause">
                                                    <text>Play</text>
                                                    <sizing><horizontal method="fixed">50</horizontal></sizing>
                                                </button>
                                                <button id="btn-next">
                                                    <text>&gt;&gt;</text>
                                                    <sizing><horizontal method="fixed">30</horizontal></sizing>
                                                    <margins><left>5</left></margins>
                                                </button>
                                            </children>
                                        </flow-layout>
                                    </children>
                                </flow-layout>
                            </children>
                        </flow-layout>
                    </children>
                </flow-layout>
            </children>
        </flow-layout>
    </components>
</owo-ui>
