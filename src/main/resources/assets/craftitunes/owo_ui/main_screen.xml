<owo-ui xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/wisp-forest/owo/1.21/owo-ui.xsd">
    <components>
        <flow-layout direction="vertical">
            <sizing>
                <width>fill</width>
                <height>fill</height>
            </sizing>
            <horizontal-alignment>center</horizontal-alignment>
            <vertical-alignment>center</vertical-alignment>

            <children>
                <!-- Main Window -->
                <flow-layout direction="horizontal">
                    <sizing>
                        <width>400</width>
                        <height>250</height>
                    </sizing>
                    <surface>
                        <panel dark="true"/>
                    </surface>
                    
                    <children>
                        <!-- Sidebar -->
                        <flow-layout direction="vertical">
                            <sizing>
                                <width>100</width>
                                <height>fill</height>
                            </sizing>
                            <padding>
                                <all>5</all>
                            </padding>
                            <surface>
                                <options-background/>
                            </surface>
                            
                            <children>
                                <label text="CraftiTunes" shadow="true">
                                    <color>#1DB954</color>
                                    <margins><bottom>10</bottom></margins>
                                </label>
                                <button id="btn-local-files" text="Local Files">
                                    <sizing><width>fill</width></sizing>
                                </button>
                                <button id="btn-playlists" text="Playlists">
                                    <sizing><width>fill</width></sizing>
                                </button>
                            </children>
                        </flow-layout>
                        
                        <!-- Main Content Area -->
                        <flow-layout direction="vertical">
                            <sizing>
                                <width>fill</width>
                                <height>fill</height>
                            </sizing>
                            <padding>
                                <all>10</all>
                            </padding>
                            
                            <children>
                                <!-- Top: Now Playing Info -->
                                <flow-layout direction="horizontal">
                                    <sizing>
                                        <width>fill</width>
                                        <height>30</height>
                                    </sizing>
                                    <vertical-alignment>center</vertical-alignment>
                                    <children>
                                        <label id="lbl-now-playing" text="Now Playing: None" shadow="true"/>
                                    </children>
                                </flow-layout>
                                
                                <!-- Middle: Track List -->
                                <scroll direction="vertical">
                                    <flow-layout direction="vertical" id="track-list">
                                        <sizing>
                                            <width>fill</width>
                                            <height>content</height>
                                        </sizing>
                                        <children>
                                            <label text="Loading tracks..."/>
                                        </children>
                                    </flow-layout>
                                    
                                    <sizing>
                                        <width>fill</width>
                                        <height>fill</height>
                                    </sizing>
                                    <margins>
                                        <top>5</top>
                                        <bottom>5</bottom>
                                    </margins>
                                </scroll>
                                
                                <!-- Bottom: Playback Controls -->
                                <flow-layout direction="horizontal">
                                    <sizing>
                                        <width>fill</width>
                                        <height>25</height>
                                    </sizing>
                                    <horizontal-alignment>center</horizontal-alignment>
                                    <vertical-alignment>center</vertical-alignment>
                                    <children>
                                        <button id="btn-prev" text="&lt;&lt;">
                                            <sizing><width>30</width></sizing>
                                            <margins><right>5</right></margins>
                                        </button>
                                        <button id="btn-play-pause" text="Play">
                                            <sizing><width>50</width></sizing>
                                        </button>
                                        <button id="btn-next" text="&gt;&gt;">
                                            <sizing><width>30</width></sizing>
                                            <margins><left>5</left></margins>
                                        </button>
                                    </children>
                                </flow-layout>
                            </children>
                        </flow-layout>
                    </children>
                </flow-layout>
            </children>
        </flow-layout>
    </components>
</owo-ui>
