<owo-ui xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/wisp-forest/owo/1.21/owo-ui.xsd">
    <components>
        <flow-layout direction="vertical">
            <sizing>
                <width>fill</width>
                <height>fill</height>
            </sizing>
            <horizontal-alignment>center</horizontal-alignment>
            <vertical-alignment>center</vertical-alignment>
            
            <children>
                <!-- Sleek Premium App Container -->
                <flow-layout direction="vertical">
                    <sizing>
                        <width>250</width>
                        <height>150</height>
                    </sizing>
                    
                    <!-- Dark sleek background -->
                    <surface>
                        <panel dark="true"/>
                    </surface>
                    
                    <padding>
                        <all>15</all>
                    </padding>

                    <children>
                        <!-- Top bar -->
                        <flow-layout direction="horizontal">
                            <sizing>
                                <width>fill</width>
                                <height>25</height>
                            </sizing>
                            <vertical-alignment>center</vertical-alignment>
                            
                            <children>
                                <label text="CraftiTunes GUI Working!" shadow="true"/>
                            </children>
                        </flow-layout>
                    </children>
                    
                </flow-layout>
            </children>
        </flow-layout>
    </components>
</owo-ui>
