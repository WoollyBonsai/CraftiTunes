<owo-ui xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/wisp-forest/owo/1.21/owo-ui.xsd">
    <components>
        <flow-layout direction="vertical">
            <sizing>
                <horizontal method="fill">100</horizontal>
                <vertical method="fill">100</vertical>
            </sizing>
            <horizontal-alignment>center</horizontal-alignment>
            <vertical-alignment>center</vertical-alignment>

            <children>
                <!-- Main Window -->
                <flow-layout direction="horizontal">
                    <sizing>
                        <horizontal method="fill">60</horizontal>
                        <vertical method="fill">75</vertical>
                    </sizing>
                    <surface>
                        <flat>#FF2B2B2B</flat>
                    </surface>
                    
                    <children>
                        <!-- Sidebar (Navbar) -->
                        <flow-layout direction="vertical">
                            <sizing>
                                <horizontal method="fixed">80</horizontal>
                                <vertical method="fill">100</vertical>
                            </sizing>
                            <padding>
                                <all>5</all>
                            </padding>
                            <surface>
                                <flat>#FF1E1E1E</flat>
                            </surface>
                            <horizontal-alignment>center</horizontal-alignment>
                            
                            <children>
                                <label>
                                    <text>CiT</text>
                                    <shadow>true</shadow>
                                    <color>#1DB954</color>
                                    <margins><bottom>20</bottom><top>10</top></margins>
                                </label>
                                
                                <flow-layout id="tab-spotify" direction="vertical">
                                    <sizing><horizontal method="fixed">50</horizontal><vertical method="fixed">40</vertical></sizing>
                                    <horizontal-alignment>center</horizontal-alignment>
                                    <vertical-alignment>center</vertical-alignment>
                                    <children>
                                        <texture texture="craftitunes:textures/gui/icons/spotify.png" texture-width="64" texture-height="64" region-width="64" region-height="64" u="0" v="0">
                                            <sizing><horizontal method="fixed">28</horizontal><vertical method="fixed">28</vertical></sizing>
                                        </texture>
                                    </children>
                                </flow-layout>
                                
                                <flow-layout id="tab-yt-music" direction="vertical">
                                    <sizing><horizontal method="fixed">50</horizontal><vertical method="fixed">40</vertical></sizing>
                                    <horizontal-alignment>center</horizontal-alignment>
                                    <vertical-alignment>center</vertical-alignment>
                                    <margins><top>10</top></margins>
                                    <children>
                                        <texture texture="craftitunes:textures/gui/icons/yt_music.png" texture-width="64" texture-height="64" region-width="64" region-height="64" u="0" v="0">
                                            <sizing><horizontal method="fixed">28</horizontal><vertical method="fixed">28</vertical></sizing>
                                        </texture>
                                    </children>
                                </flow-layout>
                                
                                <flow-layout id="tab-apple" direction="vertical">
                                    <sizing><horizontal method="fixed">50</horizontal><vertical method="fixed">40</vertical></sizing>
                                    <horizontal-alignment>center</horizontal-alignment>
                                    <vertical-alignment>center</vertical-alignment>
                                    <margins><top>10</top></margins>
                                    <children>
                                        <texture texture="craftitunes:textures/gui/icons/apple.png" texture-width="64" texture-height="64" region-width="64" region-height="64" u="0" v="0">
                                            <sizing><horizontal method="fixed">28</horizontal><vertical method="fixed">28</vertical></sizing>
                                        </texture>
                                    </children>
                                </flow-layout>
                                
                                <flow-layout id="tab-prime" direction="vertical">
                                    <sizing><horizontal method="fixed">50</horizontal><vertical method="fixed">40</vertical></sizing>
                                    <horizontal-alignment>center</horizontal-alignment>
                                    <vertical-alignment>center</vertical-alignment>
                                    <margins><top>10</top></margins>
                                    <children>
                                        <texture texture="craftitunes:textures/gui/icons/prime.png" texture-width="64" texture-height="64" region-width="64" region-height="64" u="0" v="0">
                                            <sizing><horizontal method="fixed">28</horizontal><vertical method="fixed">28</vertical></sizing>
                                        </texture>
                                    </children>
                                </flow-layout>
                                
                                <flow-layout id="tab-local" direction="vertical">
                                    <sizing><horizontal method="fixed">50</horizontal><vertical method="fixed">40</vertical></sizing>
                                    <horizontal-alignment>center</horizontal-alignment>
                                    <vertical-alignment>center</vertical-alignment>
                                    <margins><top>10</top></margins>
                                    <children>
                                        <texture texture="craftitunes:textures/gui/icons/local.png" texture-width="64" texture-height="64" region-width="64" region-height="64" u="0" v="0">
                                            <sizing><horizontal method="fixed">28</horizontal><vertical method="fixed">28</vertical></sizing>
                                        </texture>
                                    </children>
                                </flow-layout>
                                
                                <!-- Spacer -->
                                <flow-layout direction="vertical">
                                    <sizing><horizontal method="fill">100</horizontal><vertical method="fill">100</vertical></sizing>
                                </flow-layout>
                                
                                <flow-layout id="tab-settings" direction="vertical">
                                    <sizing><horizontal method="fixed">50</horizontal><vertical method="fixed">40</vertical></sizing>
                                    <horizontal-alignment>center</horizontal-alignment>
                                    <vertical-alignment>center</vertical-alignment>
                                    <margins><bottom>10</bottom></margins>
                                    <children>
                                        <texture texture="craftitunes:textures/gui/icons/settings.png" texture-width="64" texture-height="64" region-width="64" region-height="64" u="0" v="0">
                                            <sizing><horizontal method="fixed">28</horizontal><vertical method="fixed">28</vertical></sizing>
                                        </texture>
                                    </children>
                                </flow-layout>
                            </children>
                        </flow-layout>
                        
                        <!-- Main Content Area -->
                        <flow-layout direction="vertical">
                            <sizing>
                                <horizontal method="fill">100</horizontal>
                                <vertical method="fill">100</vertical>
                            </sizing>
                            <padding>
                                <all>15</all>
                            </padding>
                            
                            <children>
                                <!-- Top: Search -->
                                <text-box id="search-box">
                                    <text></text>
                                    <sizing><horizontal method="fill">100</horizontal></sizing>
                                    <margins><bottom>15</bottom></margins>
                                </text-box>
                                
                                <!-- Dynamic Content View -->
                                <scroll direction="vertical">
                                    <flow-layout direction="vertical" id="content-container">
                                        <sizing><horizontal method="fill">100</horizontal><vertical method="content"></vertical></sizing>
                                    </flow-layout>
                                    <sizing>
                                        <horizontal method="fill">100</horizontal>
                                        <vertical method="fill">75</vertical>
                                    </sizing>
                                </scroll>
                                
                                <!-- Bottom: Playback Controls -->
                                <flow-layout direction="horizontal">
                                    <sizing>
                                        <horizontal method="fill">100</horizontal>
                                        <vertical method="fixed">50</vertical>
                                    </sizing>
                                    <vertical-alignment>center</vertical-alignment>
                                    <padding><all>10</all></padding>
                                    <margins><top>15</top></margins>
                                    <surface><flat>#FF1E1E1E</flat></surface>
                                    
                                    <children>
                                        <!-- Left: Track Name -->
                                        <label id="now-playing-label">
                                            <text>Now Playing: None</text>
                                            <sizing><horizontal method="fixed">150</horizontal></sizing>
                                            <margins><right>10</right></margins>
                                        </label>
                                        
                                        <!-- Center: Slider -->
                                        <slider id="track-slider">
                                            <sizing>
                                                <horizontal method="fill">100</horizontal>
                                            </sizing>
                                            <margins><left>10</left><right>20</right></margins>
                                        </slider>
                                        
                                        <!-- Right: Buttons -->
                                        <flow-layout direction="horizontal">
                                            <sizing>
                                                <horizontal method="content"></horizontal>
                                                <vertical method="content"></vertical>
                                            </sizing>
                                            <vertical-alignment>center</vertical-alignment>
                                            <children>
                                                <button id="btn-queue">
                                                    <text>Q</text>
                                                    <sizing><horizontal method="fixed">24</horizontal><vertical method="fixed">24</vertical></sizing>
                                                    <margins><right>8</right></margins>
                                                </button>
                                                <button id="btn-prev">
                                                    <text>&lt;&lt;</text>
                                                    <sizing><horizontal method="fixed">32</horizontal><vertical method="fixed">24</vertical></sizing>
                                                </button>
                                                <button id="btn-play-pause">
                                                    <text>||</text>
                                                    <sizing><horizontal method="fixed">32</horizontal><vertical method="fixed">24</vertical></sizing>
                                                    <margins><left>5</left><right>5</right></margins>
                                                </button>
                                                <button id="btn-next">
                                                    <text>&gt;&gt;</text>
                                                    <sizing><horizontal method="fixed">32</horizontal><vertical method="fixed">24</vertical></sizing>
                                                </button>
                                            </children>
                                        </flow-layout>
                                    </children>
                                </flow-layout>
                            </children>
                        </flow-layout>
                    </children>
                </flow-layout>
            </children>
        </flow-layout>
    </components>
</owo-ui>
